---
/**
 * @file Layout.astro
 */
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

const {
  title = "Triad Systems — Soluciones de Software Premium",
  description = "Transformamos ideas en experiencias extraordinarias.",
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=Playfair+Display:ital,wght@1,400;1,700&display=swap" rel="stylesheet" />

    <ClientRouter />
  </head>
  <body>
    <slot />
  </body>
</html>