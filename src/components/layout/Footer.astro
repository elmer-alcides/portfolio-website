---
// src/components/layout/Footer.astro
---

<footer class="main-footer section-stealth">
  <div class="container">
    <div class="footer-grid">
      
      <!-- 1. Marca y Logo -->
      <div class="footer-brand">
        <a href="#home" class="logo">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="logo-arrow">
            <line x1="7" y1="17" x2="17" y2="7"></line>
            <polyline points="7 7 17 7 17 17"></polyline>
          </svg>
          <span>TRIAD SYSTEMS</span>
        </a>
        <p class="brand-desc">
          Transformando ideas en experiencias digitales con ingeniería de alta precisión.
        </p>
      </div>

      <!-- 2. Navegación Rápida -->
      <div class="footer-links">
        <h4 class="mono-title">Enlaces Rápidos</h4>
        <ul>
          <li><a href="#home">Inicio</a></li>
          <li><a href="#projects">Proyectos</a></li>
          <li><a href="#team">Equipo</a></li>
          <li><a href="#contact">Contacto</a></li>
        </ul>
      </div>

      <!-- 3. Redes Sociales (Con SVGs Reales) -->
      <div class="footer-social">
        <h4 class="mono-title">Redes Sociales</h4>
        <div class="social-icons">
          <a href="#" aria-label="GitHub" target="_blank" rel="noopener noreferrer">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.28 1.15-.28 2.35 0 3.5-.73 1.02-1.08 2.25-1 3.5 0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
          </a>
          <a href="#" aria-label="LinkedIn" target="_blank" rel="noopener noreferrer">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
          </a>
          <a href="#" aria-label="X / Twitter" target="_blank" rel="noopener noreferrer">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="4" x2="20" y2="20"/><line x1="20" y1="4" x2="4" y2="20"/></svg>
          </a>
        </div>
      </div>
      
    </div>

    <!-- 4. Footer Bottom (Copyright y Tech Stack) -->
    <div class="footer-bottom">
      <p class="copyright">&copy; {new Date().getFullYear()} Triad Systems. Todos los derechos reservados.</p>
      <div class="tech-stack">
        <span class="status-dot"></span>
        <p>Construido con <span>Astro</span> & <span>Pure CSS</span></p>
      </div>
    </div>
  </div>
</footer>

<style>
  /* === CONTENEDOR PRINCIPAL === */
  .main-footer {
    padding: 6rem 0 2rem;
    background-color: var(--bg-dark, #08080a); /* Conecta con el global */
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    position: relative;
    overflow: hidden;
  }

  /* Luz superior muy tenue para separar el footer del contacto */
  .main-footer::before {
    content: '';
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 60%;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--accent-purple, #a855f7), transparent);
    opacity: 0.3;
  }

  /* === GRID === */
  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 4rem;
    margin-bottom: 5rem;
  }

  /* === MARCA Y LOGO === */
  .logo {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    color: #ffffff;
    font-weight: 800;
    font-size: 1.2rem;
    letter-spacing: -0.02em;
    margin-bottom: 1.2rem;
    transition: opacity 0.3s ease;
  }

  .logo:hover {
    opacity: 0.8;
  }

  .logo-arrow {
    color: var(--accent-light, #d8b4fe);
  }

  .brand-desc {
    color: #a1a1aa;
    font-size: 0.95rem;
    line-height: 1.6;
    max-width: 320px;
    font-weight: 400;
  }

  /* === TÍTULOS DE COLUMNAS === */
  .mono-title {
    font-family: var(--font-mono, monospace);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #71717a; /* Zinc 500 - Sutil y técnico */
    margin-bottom: 1.5rem;
    font-weight: 600;
  }

  /* === ENLACES === */
  .footer-links ul {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }

  .footer-links a {
    text-decoration: none;
    color: #a1a1aa;
    font-size: 0.95rem;
    transition: all 0.3s ease;
    display: inline-block;
  }

  .footer-links a:hover {
    color: #ffffff;
    transform: translateX(4px); /* Micro-interacción: se mueve a la derecha */
  }

  /* === REDES SOCIALES === */
  .social-icons {
    display: flex;
    gap: 1rem;
  }

  .social-icons a {
    width: 42px;
    height: 42px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #a1a1aa;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .social-icons a:hover {
    background: rgba(168, 85, 247, 0.1);
    border-color: var(--accent-purple, #a855f7);
    color: #ffffff;
    transform: translateY(-4px);
    box-shadow: 0 4px 15px rgba(168, 85, 247, 0.2);
  }

  /* === FOOTER BOTTOM === */
  .footer-bottom {
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.85rem;
  }

  .copyright {
    color: #71717a;
  }

  .tech-stack {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: #a1a1aa;
  }

  .tech-stack span {
    color: #ffffff;
    font-weight: 600;
  }

  /* Punto de estado activo (Led verde/púrpura) */
  .status-dot {
    width: 6px;
    height: 6px;
    background-color: var(--accent-light, #d8b4fe);
    border-radius: 50%;
    box-shadow: 0 0 8px var(--accent-purple, #a855f7);
    animation: pulse-soft 3s infinite alternate;
  }

  @keyframes pulse-soft {
    0% { opacity: 0.5; }
    100% { opacity: 1; }
  }

  /* === RESPONSIVE === */
  @media (max-width: 768px) {
    .footer-grid { 
      grid-template-columns: 1fr; 
      gap: 3rem; 
      text-align: center;
    }
    .logo {
      justify-content: center;
    }
    .brand-desc {
      margin: 0 auto;
    }
    .social-icons {
      justify-content: center;
    }
    .footer-bottom { 
      flex-direction: column; 
      gap: 1.5rem; 
      text-align: center; 
    }
  }
</style>