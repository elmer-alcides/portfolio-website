---
import { team } from '../../data/team.js';
---

<section id="team" class="team-section section-secondary">
  <div class="container">
    <header class="section-header">
      <h2 class="section-title">El <span class="serif-font">Equipo</span></h2>
      <p class="section-subtitle">Mentes brillantes construyendo el futuro de la infraestructura digital.</p>
    </header>

    <div class="team-grid">
      {team.map((member) => (
        <article class="team-card">
          <!-- Efecto de resplandor detrás del avatar -->
          <div class="card-glow"></div>
          
          <div class="avatar-wrapper">
            <div class="avatar-orbit"></div>
            <div class="avatar-inner">
              {member.image ? (
                <img src={member.image} alt={`Foto de ${member.name}`} class="member-photo" loading="lazy" />
              ) : (
                <div class="avatar-placeholder">
                  <span>{member.name.split(' ').map((n: string) => n[0]).join('')}</span>
                </div>
              )}
            </div>
          </div>

          <div class="member-info">
            <span class="member-role">{member.role}</span>
            <h3 class="member-name">{member.name}</h3>
            <p class="member-bio">{member.description}</p>
            
            <div class="member-social">
              {member.links?.github && (
                <a href={member.links.github} aria-label={`Perfil de GitHub de ${member.name}`} target="_blank" rel="noopener noreferrer">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.28 1.15-.28 2.35 0 3.5-.73 1.02-1.08 2.25-1 3.5 0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/>
                    <path d="M9 18c-4.51 2-5-2-7-2"/>
                  </svg>
                </a>
              )}
              {member.links?.linkedin && (
                <a href={member.links.linkedin} aria-label={`Perfil de LinkedIn de ${member.name}`} target="_blank" rel="noopener noreferrer">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
                    <rect width="4" height="12" x="2" y="9"/>
                    <circle cx="4" cy="4" r="2"/>
                  </svg>
                </a>
              )}
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  /* === CONTENEDOR === */
  .team-section {
    padding: 8rem 0; 
  }

  /* === HEADER === */
  .section-header {
    text-align: center;
    margin-bottom: 5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .section-title {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 800;
    color: #ffffff;
    letter-spacing: -0.03em;
  }

  /* Consistencia: El mismo gradiente para "Equipo" que usamos para "Destacados" y "experiencias" */
  .serif-font {
    font-family: var(--font-serif, "Playfair Display", serif);
    font-style: italic;
    font-weight: 500;
    background: linear-gradient(135deg, var(--accent-light, #d8b4fe) 0%, #ec4899 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    padding: 0 0.05em;
    display: inline-block;
  }

  .section-subtitle {
    color: #a1a1aa;
    margin-top: 1rem;
    font-size: 1.1rem;
    max-width: 600px;
    font-weight: 400;
  }

  /* === GRID === */
  .team-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2.5rem;
  }

  /* === TARJETA DE EQUIPO === */
  .team-card {
    background: var(--bg-card, #131316); /* Encapsulamos en tarjetas para orden visual */
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 24px;
    padding: 3.5rem 2rem 2.5rem 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    position: relative;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    overflow: hidden;
  }

  .team-card:hover {
    transform: translateY(-8px);
    border-color: rgba(168, 85, 247, 0.3);
    background: rgba(255, 255, 255, 0.02);
  }

  /* Luz superior tenue en cada tarjeta */
  .card-glow {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 150px;
    height: 150px;
    background: radial-gradient(circle, rgba(168, 85, 247, 0.15) 0%, transparent 70%);
    opacity: 0;
    transition: opacity 0.5s ease;
    pointer-events: none;
  }

  .team-card:hover .card-glow {
    opacity: 1;
  }

  /* === AVATAR (Órbita Técnica) === */
  .avatar-wrapper {
    position: relative;
    width: 120px; /* Un poco más refinado */
    height: 120px;
    margin-bottom: 2rem;
    z-index: 2;
  }

  .avatar-orbit {
    position: absolute;
    inset: -10px;
    border: 1px dashed rgba(255, 255, 255, 0.15); /* Efecto órbita en lugar de borde sólido */
    border-radius: 50%;
    transition: all 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .team-card:hover .avatar-orbit {
    transform: scale(1.15) rotate(90deg); /* Animación técnica al pasar el ratón */
    border-color: var(--accent-light, #d8b4fe);
    border-style: solid;
    box-shadow: 0 0 20px -5px rgba(168, 85, 247, 0.4);
  }

  .avatar-inner {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    overflow: hidden;
    background: #000;
    position: relative;
    z-index: 1;
  }

  .member-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(1) contrast(1.1); /* Efecto B&N Premium */
    transition: filter 0.5s ease, transform 0.5s ease;
  }

  .team-card:hover .member-photo {
    filter: grayscale(0) contrast(1); /* Recupera color */
    transform: scale(1.05); /* Zoom sutil */
  }

  /* === INFO DEL MIEMBRO === */
  .member-info {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex: 1;
    z-index: 2;
  }

  .member-role {
    font-family: var(--font-mono, monospace);
    font-size: 0.75rem;
    color: var(--accent-light, #d8b4fe); /* Mejor contraste que el morado oscuro */
    text-transform: uppercase;
    letter-spacing: 0.2em;
    margin-bottom: 0.8rem;
    font-weight: 600;
  }

  .member-name {
    font-size: 1.6rem;
    font-weight: 700;
    color: #ffffff;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }

  .member-bio {
    color: #a1a1aa;
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: 2rem;
    font-weight: 400;
    max-width: 280px; /* Mantiene la bio simétrica */
  }

  /* === REDES SOCIALES=== */
  .member-social {
    display: flex;
    gap: 1rem;
    justify-content: center;
    border-top: 1px solid rgba(255, 255, 255, 0.08); /* Línea divisoria más sutil */
    padding-top: 1.5rem;
    width: 100%;
    margin-top: auto; /* Empuja los iconos al fondo */
  }

  .member-social a {
    color: #71717a; /* Un gris claro, 100% visible pero no distrae */
    padding: 0.5rem;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.03);
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .member-social a:hover {
    color: #ffffff;
    background: var(--accent-purple, #a855f7); /* Botón se ilumina al interactuar */
    transform: translateY(-3px);
    box-shadow: 0 5px 15px -5px rgba(168, 85, 247, 0.5);
  }

  @media (max-width: 768px) {
    .team-grid { 
      grid-template-columns: 1fr; 
      max-width: 400px;
      margin: 0 auto;
    }
  }
</style>